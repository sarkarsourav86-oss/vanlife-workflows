# Copy to .env and fill in. Never commit .env.

# Campflare API — get from https://campflare.com/platform
CAMPFLARE_API_KEY=

# Campflare webhook JWT shared secret — from account page at https://campflare.com/platform.
# Campflare signs every webhook POST with HS256 using this secret; our handler must
# verify the `Authorization` header before trusting the payload. Without this set,
# Campflare returns `missing-jwt-secret-key` and does not deliver webhooks at all.
CAMPFLARE_JWT_SECRET=

# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Discord webhook — right-click a channel > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=

# Public URL Campflare should POST alert webhooks to.
# When deployed on Modal, this is the modal_app.py webhook endpoint URL.
# Leave blank for local testing.
CAMPFLARE_WEBHOOK_URL=
